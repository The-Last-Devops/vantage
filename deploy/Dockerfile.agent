# syntax=docker/dockerfile:1
# Tiny agent image: a static musl binary on `scratch` (no OS, no libc, no certs —
# rustls' webpki roots are compiled in). cargo-chef caches the dependency layer so
# code-only pushes don't recompile the whole tree (slow, esp. under arm64).
# Built natively per-arch (no QEMU); the musl triple is derived from the build host.
FROM rust:1-bookworm AS chef
# Retry transient crate downloads (CI hit "curl failed" fetching a crate). Inherited
# by the planner/build stages that derive from `chef`.
ENV CARGO_NET_RETRY=10
RUN cargo install cargo-chef --locked
WORKDIR /app

FROM chef AS planner
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
RUN cargo chef prepare --recipe-path recipe.json

FROM chef AS build
RUN apt-get update && apt-get install -y --no-install-recommends musl-tools \
    && rm -rf /var/lib/apt/lists/*
RUN rustup target add "$(uname -m)-unknown-linux-musl"
COPY --from=planner /app/recipe.json recipe.json
RUN cargo chef cook --release --target "$(uname -m)-unknown-linux-musl" -p vantage-agent --recipe-path recipe.json
COPY Cargo.toml Cargo.lock ./
COPY crates ./crates
# Build id + release channel baked via build.rs (build metadata). Set per CI build:
# GIT_SHA=<commit>, VANTAGE_CHANNEL=main/stable/dev.
ARG GIT_SHA=""
ARG VANTAGE_CHANNEL=dev
ENV GIT_SHA=$GIT_SHA VANTAGE_CHANNEL=$VANTAGE_CHANNEL
RUN cargo build --release --target "$(uname -m)-unknown-linux-musl" -p vantage-agent \
    && cp "target/$(uname -m)-unknown-linux-musl/release/vantage-agent" /vantage-agent

FROM scratch
COPY --from=build /vantage-agent /vantage-agent
ENTRYPOINT ["/vantage-agent"]
