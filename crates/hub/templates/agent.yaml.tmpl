# vantage agent — DaemonSet (one pod per node, reports host metrics).
# Rendered by the hub; apply directly:
#   kubectl apply -f "<HUB_URL>/pub/agent.yaml?key=YOUR_KEY&cluster=YOUR_CLUSTER"
---
apiVersion: v1
kind: Namespace
metadata:
  name: <NAMESPACE>
---
apiVersion: v1
kind: Secret
metadata:
  name: vantage-agent
  namespace: <NAMESPACE>
type: Opaque
stringData:
  api-key: "<API_KEY>"
---
apiVersion: apps/v1
kind: DaemonSet
metadata:
  name: vantage-agent
  namespace: <NAMESPACE>
  labels: { app: vantage-agent }
spec:
  selector:
    matchLabels: { app: vantage-agent }
  template:
    metadata:
      labels: { app: vantage-agent }
    spec:
      hostNetwork: true              # report host interfaces
      hostPID: true                  # see host processes (host-level CPU/mem)
      dnsPolicy: ClusterFirstWithHostNet
      tolerations:                   # also run on control-plane nodes
        - operator: Exists
      containers:
        - name: agent
          image: "<IMAGE>"
          imagePullPolicy: Always   # rolling tag is mutable; always pull the latest build
          env:
            - name: HUB_URL
              value: "<HUB_URL>"
            - name: AGENT_KIND
              value: "k8s"
            - name: CLUSTER
              value: "<CLUSTER>"
            - name: AUTO_UPDATE        # 1 = self-restart to follow the hub (auto-update channel)
              value: "<AUTO_UPDATE>"
            - name: ALLOW_SHELL        # 1 = open the reverse shell tunnel (on by default; set 0 to disable)
              value: "1"
            - name: DISK_PATH
              value: "/host"
            - name: NODE_NAME            # stable identity = k8s node name
              valueFrom:
                fieldRef:
                  fieldPath: spec.nodeName
            - name: API_KEY
              valueFrom:
                secretKeyRef:
                  name: vantage-agent
                  key: api-key
          resources:
            requests: { cpu: 20m, memory: 32Mi }
            limits: { memory: 128Mi }
          volumeMounts:
            - { name: host-root, mountPath: /host, readOnly: true }
      volumes:
        - name: host-root
          hostPath: { path: / }
